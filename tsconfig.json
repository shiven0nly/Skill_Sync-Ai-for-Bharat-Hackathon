{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "include": [".kiro/**/*.ts", "src/**/*.ts", "examples/**/*.ts", "test-*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "frontend/**/*.test.ts"]
}
