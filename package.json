{
  "name": "skill-sync",
  "version": "0.1.0",
  "description": "Developer cognitive load analyzer with Tree-sitter parsing",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "npm run build && node dist/.kiro/core/api/cli.js",
    "server": "npm run build && node dist/.kiro/core/api/cli.js server",
    "server:dev": "tsc && node dist/src/server.js",
    "test:integration": "npm run build && node dist/test-api-integration.js",
    "test:streaming": "npm run build && node dist/test-streaming-integration.js",
    "example:streaming": "npm run build && node dist/examples/streaming-bridge-usage.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "web-tree-sitter": "^0.20.8"
  }
}
